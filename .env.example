# Copy to .env.local and fill in. NEVER commit .env.local.
#   cp .env.example .env.local
#
# Every variable this project reads must be declared here, commented, with a blank
# or dummy value. This file is the env contract; do not document vars in prose only.
#
# Declare ONLY what this project actually reads. A var that ships here but is never read
# is a false contract: the next person wires it up, or spends an afternoon looking for the
# code that consumes it. The examples below are commented out for exactly that reason —
# uncomment the ones you use and delete the rest.

# --- Core ---
# Deployment environment: local | staging | production
APP_ENV=local

# --- Examples: uncomment only what this project reads ---
#
# Google Cloud, service-account auth (see SECURITY.md). Absolute path to the
# service-account JSON; the file itself is gitignored.
# GOOGLE_SERVICE_ACCOUNT_KEY=
# user = local OAuth flow; service_account = Cloud Run
# AUTH_MODE=user
#
# Secrets — fill these in .env.local, never here.
# API_KEY=
# SLACK_BOT_TOKEN=
# DATABASE_URL=
